# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===========================================
DATABASE_NAME=ecommerce_app_project_development
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Base de datos de prueba
TEST_DATABASE_NAME=ecommerce_app_project_test

# ===========================================
# CONFIGURACIÓN DE RAILS
# ===========================================
# Rails master key (genera una nueva con: rails credentials:edit)
# RAILS_MASTER_KEY=tu_master_key_aqui

# ===========================================
# CONFIGURACIÓN DE PAGOS - STRIPE
# ===========================================
# Claves de Stripe (obtén las tuyas en https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_de_stripe_aqui
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_de_stripe_aqui
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret_de_stripe_aqui

# ===========================================
# CONFIGURACIÓN DE PAGOS - PAYPAL
# ===========================================
# Claves de PayPal (obtén las tuyas en https://developer.paypal.com/)
PAYPAL_CLIENT_ID=tu_client_id_de_paypal_aqui
PAYPAL_CLIENT_SECRET=tu_client_secret_de_paypal_aqui
PAYPAL_MODE=sandbox  # Cambia a 'live' para producción

# ===========================================
# CONFIGURACIÓN DE EMAIL
# ===========================================
# Para desarrollo, puedes usar Mailtrap o similar
SMTP_ADDRESS=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=tu_username_de_mailtrap
SMTP_PASSWORD=tu_password_de_mailtrap
SMTP_DOMAIN=localhost:3000

# ===========================================
# CONFIGURACIÓN DE ALMACENAMIENTO
# ===========================================
# Para desarrollo local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=

# ===========================================
# CONFIGURACIÓN DE SEGURIDAD
# ===========================================
# Secret key para JWT tokens
JWT_SECRET_KEY=tu_jwt_secret_key_muy_segura_aqui

# ===========================================
# CONFIGURACIÓN DE DESARROLLO
# ===========================================
# Para desarrollo local
RAILS_ENV=development
RAILS_MAX_THREADS=5
