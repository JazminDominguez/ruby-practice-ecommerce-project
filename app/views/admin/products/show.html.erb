<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="mb-6">
    <%= link_to '← Volver a la lista de productos', admin_products_path, 
        class: "text-gray-600 hover:text-gray-900 underline mb-4 inline-block" %>
    <h1 class="text-3xl font-bold text-gray-900"><%= @product.name %></h1>
  </div>

  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6">
      <div>
        <% if @product.images.attached? %>
          <div class="space-y-4">
            <div class="aspect-square rounded-lg overflow-hidden">
              <%= image_tag @product.images.first, class: "w-full h-full object-cover" %>
            </div>
            <% if @product.images.count > 1 %>
              <div class="grid grid-cols-4 gap-2">
                <% @product.images.each do |image| %>
                  <%= image_tag image, class: "w-full h-20 object-cover rounded-md" %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="aspect-square bg-gray-200 rounded-lg flex items-center justify-center">
            <span class="text-gray-400">Sin imagen</span>
          </div>
        <% end %>
      </div>

      <div class="space-y-4">
        <div>
          <h2 class="text-sm font-medium text-gray-500">Descripción</h2>
          <p class="mt-1 text-gray-900"><%= @product.description || 'Sin descripción' %></p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <h2 class="text-sm font-medium text-gray-500">Precio</h2>
            <p class="mt-1 text-2xl font-bold text-gray-900">$<%= number_with_precision(@product.price, precision: 2) %></p>
          </div>

          <div>
            <h2 class="text-sm font-medium text-gray-500">Stock</h2>
            <p class="mt-1">
              <span class="px-3 py-1 text-sm font-semibold rounded-full <%= @product.stock > 0 ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= @product.stock %> unidades
              </span>
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <h2 class="text-sm font-medium text-gray-500">Categoría</h2>
            <p class="mt-1 text-gray-900"><%= @product.category&.name || 'N/A' %></p>
          </div>

          <div>
            <h2 class="text-sm font-medium text-gray-500">Marca</h2>
            <p class="mt-1 text-gray-900"><%= @product.brand&.name || 'N/A' %></p>
          </div>
        </div>

        <div class="pt-4 border-t border-gray-200">
          <div class="flex space-x-3">
            <%= link_to 'Editar', edit_admin_product_path(@product), 
                class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700" %>
            <%= link_to 'Eliminar', admin_product_path(@product), 
                method: :delete, 
                data: { confirm: '¿Estás seguro de eliminar este producto?' },
                class: "px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

