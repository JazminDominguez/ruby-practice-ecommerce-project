<%= form_with model: [:admin, @product], local: true, multipart: true, class: "space-y-6" do |form| %>
  <% if @product.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h3 class="text-red-800 font-medium mb-2">
        <%= pluralize(@product.errors.count, "error") %> impidieron guardar el producto:
      </h3>
      <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nombre del Producto", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :name, 
        class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= form.label :description, "Descripción", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 4,
        class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :price, "Precio", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :price, step: 0.01, min: 0,
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :stock, "Stock", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :stock, min: 0,
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :category_id, "Categoría", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :category_id, 
          options_from_collection_for_select(@categories, :id, :name, @product.category_id),
          { prompt: "Selecciona una categoría" },
          { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
    </div>

    <div>
      <%= form.label :brand_id, "Marca", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :brand_id, 
          options_from_collection_for_select(@brands, :id, :name, @product.brand_id),
          { prompt: "Selecciona una marca" },
          { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
    </div>
  </div>

  <div>
    <%= form.label :images, "Imágenes", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :images, multiple: true, accept: "image/*",
        class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    <p class="mt-1 text-sm text-gray-500">Puedes seleccionar múltiples imágenes</p>
    
    <% if @product.images.attached? %>
      <div class="mt-4 grid grid-cols-4 gap-4">
        <% @product.images.each do |image| %>
          <div class="relative">
            <%= image_tag image, class: "w-full h-32 object-cover rounded-md" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="flex justify-end space-x-4 pt-4">
    <%= link_to 'Cancelar', admin_products_path, 
        class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50" %>
    <%= form.submit @product.new_record? ? "Crear Producto" : "Actualizar Producto",
        class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>

