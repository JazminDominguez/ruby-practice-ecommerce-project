<div class="bg-neutral-gray">
  <h1 class="font-bold text-4xl">Dashboard#customer</h1>
  <p>Find me in app/views/dashboard/customer.html.erb</p>
  <div class="flex flex-col"> 
       <%= render 'shared/category_filter' %>
    <div class="flex flex-row"> 
     <%= render 'shared/filter_sidebar' %>
      <!-- Productos reales de la base de datos -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if @products.any? %>
          <% @products.each do |product| %>
            <%= render 'shared/product_cards', product: product %>
          <% end %>
        <% else %>
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500 text-lg">No hay productos disponibles en este momento.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <%= form_with url: destroy_user_session_path, method: :delete, local: true, class: "inline" do |f| %>
    <%= f.submit "Cerrar Sesión", 
        data: { confirm: "¿Estás seguro de que quieres cerrar sesión?" },
        class: "bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium mt-8 cursor-pointer" %>
  <% end %>
</div>
